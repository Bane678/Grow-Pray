{
  "expo": {
    "name": "Grow Pray",
    "slug": "grow-pray",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon-ios-1024.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0d1b2d",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Garden Assets/Icons/Loading_Screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#0f1526"
    },
    "ios": {
      "icon": "./assets/app-icon-ios-1024.png",
      "bundleIdentifier": "com.antigravity.growpray",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Grow Pray uses your location to calculate accurate prayer times for your area.",
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.antigravity.growpray",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Garden Assets/Icons/App_Logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/Garden Assets/Icons/App_Logo.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Grow Pray uses your location to calculate accurate prayer times for your area."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/Garden Assets/Icons/App_Logo.png",
          "color": "#0f1526"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b4abc15f-4bf1-4add-979f-122f1c51bcb7"
      }
    }
  }
}
